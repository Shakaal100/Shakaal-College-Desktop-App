<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<?import javafx.scene.image.ImageView?>
<BorderPane stylesheets="@../css/students.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.shakaal.collegemanagementapp.controllers.StudentController">

    <!-- ========================= -->
    <!-- TOP SECTION -->
    <!-- ========================= -->

    <top>

        <VBox spacing="15" styleClass="top-container">

            <padding>
                <Insets bottom="10" left="20" right="20" top="20" />
            </padding>

            <children>

                <Label styleClass="page-title" text="Students Management" />

                <HBox alignment="CENTER_LEFT" spacing="15">

                    <children>

                        <HBox prefWidth="350"
                              prefHeight="45"
                              spacing="12"
                              alignment="CENTER_LEFT"
                              styleClass="search-box">

                            <ImageView fx:id="searchIcon"
                                       fitWidth="24"
                                       fitHeight="24"
                                       preserveRatio="true"/>

                            <TextField fx:id="searchField"
                                       promptText="Search students..."
                                       styleClass="search-field"
                                       HBox.hgrow="ALWAYS"/>
                        </HBox>

                        <Region HBox.hgrow="ALWAYS" />

                        <Button fx:id="addStudentButton" styleClass="add-button" text="+ Add Student" />

                    </children>

                </HBox>

            </children>

        </VBox>

    </top>

    <!-- ========================= -->
    <!-- CENTER -->
    <!-- ========================= -->

    <center>

        <VBox spacing="15" styleClass="content-container">

            <padding>
                <Insets bottom="20" left="20" right="20" top="10" />
            </padding>

            <children>

                <Label fx:id="totalStudentsLabel" styleClass="student-count" text="Total Students : 0" />

                <TableView fx:id="studentTable" VBox.vgrow="ALWAYS">

                    <columns>

                        <TableColumn fx:id="idColumn" prefWidth="50" text="ID" />

                        <TableColumn fx:id="firstNameColumn" prefWidth="170" text="First Name" />

                        <TableColumn fx:id="lastNameColumn" prefWidth="170" text="Last Name" />

                        <TableColumn fx:id="genderColumn" prefWidth="110" text="Gender" />

                        <TableColumn fx:id="dobColumn" prefWidth="170" text="Date of Birth" />

                        <TableColumn fx:id="phoneColumn" prefWidth="160" text="Phone" />

                        <TableColumn fx:id="courseColumn" prefWidth="180" text="Course" />

                        <TableColumn fx:id="actionsColumn" prefWidth="220" text="Actions" />

                    </columns>

                </TableView>

            </children>

        </VBox>

    </center>

</BorderPane>
